# PQS Environment Variables
# Copy to .env and fill in values

# ── Runtime environment ──────────────────────────────────────────────
PQS_ENV=local                        # local | staging | aws

# ── Paths (override defaults; defaults are relative to project root) ─
# PQS_DATA_DIR=data
# PQS_REPORTS_DIR=reports
# PQS_CONFIG_DIR=config

# ── Logging ──────────────────────────────────────────────────────────
PQS_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Optional: future data provider API keys ───────────────────────────
# POLYGON_API_KEY=
# FINNHUB_API_KEY=
# OPENAI_API_KEY=
